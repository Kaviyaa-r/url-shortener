# The port number on which the express server will listen
PORT=5000

# MongoDB Connection URI (e.g. MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/snaplink?retryWrites=true&w=majority

# JWT signing key (must be at least 32 characters for security)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters

# The base URL of the client application (Frontend) for CORS mapping
FRONTEND_URL=http://localhost:3000

# The base URL of the redirection/shortener service for creating short links
BASE_URL=http://localhost:5000
